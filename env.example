# --- Telegram ---
# @BotFather dan oling (https://t.me/BotFather), bot nomi: Lingorider_bot
BOT_TOKEN=123456789:your-telegram-bot-token-here

# Sizning shaxsiy Telegram ID raqamingiz (admin).
# Bilish uchun @userinfobot ga /start yozing.
ADMIN_ID=5816903954

# --- Gemini (BEPUL) ---
# https://aistudio.google.com/apikey saytidan bepul oling.
# Bepul tarifda kuniga so'rov limiti bor, lekin shaxsiy/kichik bot uchun yetarli.
GEMINI_API_KEY=your-free-gemini-api-key-here

# --- Whisper (lokal, pul talab qilmaydi) ---
# tiny / base / small / medium - kompyuter quvvatiga qarab tanlang.
# "small" eng yaxshi muvozanat (aniqlik/tezlik), lekin "base" tezroq ishlaydi.
WHISPER_MODEL_SIZE=small

# Vaqt zonasi (hisobotlar uchun)
TIMEZONE=Asia/Tashkent
